<?xml version="1.0"?>
<robot name="wiezyczka_pan_tilt">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pan_tilt_description/meshes/base.stl" />
      </geometry>
    </visual>
  </link>

  <joint name="pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="pan_link"/>
    <origin xyz="0 0 40" rpy="0 0 0"/> 
    <axis xyz="0 0 1"/> 
    <limit lower="-3.14" upper="3.14" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="pan_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pan_tilt_description/meshes/pan_link.stl" />
      </geometry>
    </visual>
  </link>

  <joint name="tilt_joint" type="revolute">
    <parent link="pan_link"/>
    <child link="tilt_link"/>
    <origin xyz="10 0 120" rpy="0 0 3.14159"/> 
    <axis xyz="1 0 0"/> 
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="tilt_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/> 
      <geometry>
        <mesh filename="package://pan_tilt_description/meshes/tilt_link.stl" />
      </geometry>
    </visual>
  </link>

</robot>